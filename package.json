{
  "name": "energy-logix",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-Asset Diluent Blender & Pipeline Disruption Simulator",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "npm run docker:up && npx --yes wait-on tcp:localhost:5433 && npm run db:migrate:deploy && npm run db:seed",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev --workspace=@energy-logix/api\" \"npm run dev --workspace=@energy-logix/web\"",
    "dev:web": "npm run dev --workspace=@energy-logix/web",
    "dev:api": "npm run dev --workspace=@energy-logix/api",
    "build": "turbo run build",
    "db:generate": "npm run generate --workspace=@energy-logix/database",
    "db:migrate": "npm run migrate --workspace=@energy-logix/database",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=@energy-logix/database",
    "db:seed": "npm run seed --workspace=@energy-logix/database",
    "db:reset": "npm run reset --workspace=@energy-logix/database",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.2"
}
