# PostgreSQL
DATABASE_URL="postgresql://energy_logix:energy_logix_dev@localhost:5433/energy_logix?schema=public"

# API
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# Live SCADA telemetry simulator (set false to disable background polling)
SCADA_SIMULATOR_ENABLED=true
SCADA_INTERVAL_MS=15000

# ERP webhook delivery worker
ERP_DELIVERY_INTERVAL_MS=30000

# Commercial Trading Desk webhook (optional — demo mode acks locally if empty)
TRADING_DESK_WEBHOOK_URL=

# SAP ERP / enterprise webhook (optional — inventory snapshots & alerts)
ERP_WEBHOOK_URL=
